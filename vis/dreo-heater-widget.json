[
  {
    "_id": "w_dreo_heater_card",
    "tpl": "tplHtml",
    "widgetSet": "basic",
    "style": {
      "left": "40px",
      "top": "40px",
      "width": "420px",
      "height": "560px"
    },
    "data": {
      "refreshInterval": "0",
      "html": "<style>\n.dreo-card{box-sizing:border-box;width:100%;height:100%;min-width:320px;min-height:260px;padding:22px;border-radius:18px;background:#15181c;color:#f7f9fb;font-family:Arial,Helvetica,sans-serif;box-shadow:0 18px 45px rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.08);overflow:hidden}.dreo-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px}.dreo-title{font-size:26px;font-weight:700;line-height:1.1}.dreo-model{margin-top:6px;color:#9aa4af;font-size:13px}.dreo-pill{padding:7px 12px;border-radius:999px;background:rgba(255,255,255,.08);font-size:13px;color:#cfd7df}.dreo-temp{display:flex;align-items:flex-end;gap:12px;margin-top:24px}.dreo-current{font-size:64px;font-weight:800;letter-spacing:0}.dreo-unit{font-size:22px;color:#aeb8c2;margin-bottom:10px}.dreo-target{margin-left:auto;text-align:right;color:#cfd7df}.dreo-target b{display:block;color:#fff;font-size:24px;margin-top:4px}.dreo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:22px}.dreo-btn{height:42px;border:0;border-radius:10px;background:#27313a;color:#f7f9fb;font-size:14px;font-weight:700;cursor:pointer}.dreo-btn:hover{background:#34414c}.dreo-btn.primary{background:#ff7040;color:#151515}.dreo-btn.cool{background:#2378a8}.dreo-row{display:flex;gap:10px;margin-top:10px}.dreo-row .dreo-btn{flex:1}.dreo-meta{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:18px}.dreo-kv{background:rgba(255,255,255,.055);border-radius:10px;padding:10px 12px}.dreo-kv span{display:block;color:#9aa4af;font-size:12px}.dreo-kv b{display:block;margin-top:4px;font-size:16px}.dreo-footer{margin-top:14px;color:#77828d;font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}@media(max-width:480px){.dreo-card{padding:16px;border-radius:14px}.dreo-current{font-size:48px}.dreo-grid{grid-template-columns:1fr 1fr}.dreo-meta{grid-template-columns:1fr}}\n</style>\n<div class=\"dreo-card\">\n  <div class=\"dreo-head\">\n    <div><div class=\"dreo-title\">{__DREO_DEVICE__.info.name}</div><div class=\"dreo-model\">{__DREO_DEVICE__.info.model}</div></div>\n    <div class=\"dreo-pill\">{__DREO_DEVICE__.status.mode}</div>\n  </div>\n  <div class=\"dreo-temp\"><div class=\"dreo-current\">{__DREO_DEVICE__.status.currentTemperature}</div><div class=\"dreo-unit\">&deg;</div><div class=\"dreo-target\"><span>Ziel</span><b>{__DREO_DEVICE__.status.targetTemperature}&deg;</b></div></div>\n  <div class=\"dreo-grid\">\n    <button class=\"dreo-btn primary\" onclick=\"vis.setValue('__DREO_DEVICE__.control.power',true)\">Ein</button>\n    <button class=\"dreo-btn\" onclick=\"vis.setValue('__DREO_DEVICE__.control.power',false)\">Aus</button>\n    <button class=\"dreo-btn cool\" onclick=\"vis.setValue('__DREO_DEVICE__.control.mode','coolair')\">Cool Air</button>\n    <button class=\"dreo-btn\" onclick=\"vis.setValue('__DREO_DEVICE__.control.mode','hotair')\">Heat</button>\n    <button class=\"dreo-btn\" onclick=\"vis.setValue('__DREO_DEVICE__.control.mode','eco')\">Eco</button>\n    <button class=\"dreo-btn\" onclick=\"vis.setValue('__DREO_DEVICE__.control.fanSpeed',1)\">H1</button>\n    <button class=\"dreo-btn\" onclick=\"vis.setValue('__DREO_DEVICE__.control.fanSpeed',2)\">H2</button>\n    <button class=\"dreo-btn\" onclick=\"vis.setValue('__DREO_DEVICE__.control.fanSpeed',3)\">H3</button>\n    <button class=\"dreo-btn\" onclick=\"vis.setValue('__DREO_DEVICE__.control.oscillation',true)\">Swing</button>\n  </div>\n  <div class=\"dreo-row\">\n    <button class=\"dreo-btn\" onclick=\"(function(){var oid='__DREO_DEVICE__.control.targetTemperature';var v=parseFloat(vis.states[oid+'.val']);if(isNaN(v)){v=parseFloat('{__DREO_DEVICE__.status.targetTemperature}')}if(!isNaN(v)){vis.setValue(oid,Math.round((v-1)*10)/10)}})()\">- 1&deg;</button>\n    <button class=\"dreo-btn\" onclick=\"(function(){var oid='__DREO_DEVICE__.control.targetTemperature';var v=parseFloat(vis.states[oid+'.val']);if(isNaN(v)){v=parseFloat('{__DREO_DEVICE__.status.targetTemperature}')}if(!isNaN(v)){vis.setValue(oid,Math.round((v+1)*10)/10)}})()\">+ 1&deg;</button>\n  </div>\n  <div class=\"dreo-meta\">\n    <div class=\"dreo-kv\"><span>Power</span><b>{__DREO_DEVICE__.status.power}</b></div>\n    <div class=\"dreo-kv\"><span>Level</span><b>{__DREO_DEVICE__.status.fanSpeed}</b></div>\n    <div class=\"dreo-kv\"><span>Online</span><b>{__DREO_DEVICE__.info.online}</b></div>\n    <div class=\"dreo-kv\"><span>Timer</span><b>{__DREO_DEVICE__.status.timer}</b></div>\n  </div>\n  <div class=\"dreo-footer\">{__DREO_DEVICE__.info.deviceId}</div>\n</div>"
    }
  }
]
