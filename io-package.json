{
  "common": {
    "name": "dreo",
    "version": "0.0.10",
    "title": "Dreo",
    "titleLang": {
      "en": "Dreo",
      "de": "Dreo"
    },
    "desc": {
      "en": "Controls Dreo smart devices through the native Dreo Cloud API.",
      "de": "Steuert Dreo Smart Devices ueber die native Dreo Cloud API."
    },
    "authors": ["Alexander Tartler"],
    "keywords": ["dreo", "heater", "smart home", "cloud"],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "main": "build/main.js",
    "icon": "dreo.png",
    "extIcon": "https://raw.githubusercontent.com/alexandertartler-web/iobroker.dreo/main/admin/dreo.png",
    "mode": "daemon",
    "enabled": false,
    "materialize": true,
    "compact": true,
    "connectionType": "cloud",
    "dataSource": "poll",
    "adminUI": {
      "config": "json"
    },
    "dependencies": [
      {
        "js-controller": ">=5.0.0"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=6.17.0"
      }
    ],
    "encryptedNative": ["password"],
    "protectedNative": ["password"],
    "type": "climate-control",
    "readme": "https://github.com/alexandertartler-web/iobroker.dreo/blob/main/README.md",
    "tier": 3,
    "loglevel": "info"
  },
  "native": {
    "email": "",
    "password": "",
    "pollingInterval": 60,
    "deviceFilter": "",
    "temperatureUnit": "celsius",
    "debugMode": false
  },
  "objects": [],
  "instanceObjects": []
}
